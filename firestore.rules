rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    // ─── Users ───
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);
    }

    // ─── Clients ───
    match /clients/{clientId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() &&
        (resource.data.coachId == request.auth.uid ||
         resource.data.clientUserId == request.auth.uid);
    }

    // ─── Programs ───
    match /programs/{programId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() &&
        resource.data.coachId == request.auth.uid;
    }

    // ─── Program Assignments ───
    match /program_assignments/{assignmentId} {

      allow read: if isAuth() &&
        (request.auth.uid == resource.data.clientId ||
         request.auth.uid == resource.data.coachId);

      allow create: if isAuth() &&
        request.resource.data.coachId == request.auth.uid;

      allow update: if isAuth() &&
        (request.auth.uid == resource.data.coachId ||
         request.auth.uid == resource.data.clientId);

      allow delete: if isAuth() &&
        request.auth.uid == resource.data.coachId;

      // ─── Sessions ───
      match /sessions/{sessionId} {
        allow read, write: if isAuth() &&
          (request.auth.uid == resource.data.clientId ||
           request.auth.uid == resource.data.coachId);

        // ─── Exercises ───
        match /exercises/{exerciseId} {
          allow read, write: if isAuth() &&
            (request.auth.uid == resource.data.clientId ||
             request.auth.uid == resource.data.coachId);
        }
      }
    }

    // ─── Nutrition Assignments ───
    match /nutrition_assignments/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() &&
        (resource.data.coachId == request.auth.uid ||
         resource.data.clientId == request.auth.uid);
    }

    // ─── Coach Tips ───
    match /coach_tips/{tipId} {
      allow read: if isAuth();
      allow write: if isAuth() &&
        request.resource.data.coachId == request.auth.uid;
    }

    // ─── Coach Meals ───
    match /coach_meals/{mealId} {
      allow read: if isAuth();
      allow write: if isAuth() &&
        request.resource.data.coachId == request.auth.uid;
    }

    // ─── Conversations & Messages ───
    match /conversations/{conversationId} {
      allow read, write: if isAuth() &&
        (request.auth.uid == resource.data.clientId ||
         request.auth.uid == resource.data.coachId);
      allow create: if isAuth();

      match /messages/{messageId} {
        allow read, write: if isAuth() &&
          (request.auth.uid == resource.data.clientId ||
           request.auth.uid == resource.data.coachId);
        allow create: if isAuth();
      }
    }

    // ─── Legacy Exercise Completions ───
    match /exercise_completions/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() &&
        (request.resource.data.userId == request.auth.uid ||
         resource.data.userId == request.auth.uid);
    }
  }
}